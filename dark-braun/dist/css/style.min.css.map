$font-family: "Cormorant Garamond", sans-serif
$second-family: "Manrope", sans-serif
$third-family: "Montserrat", sans-serif
$font3: "Cormorant Infant", sans-serif
$font4: "Cossette Texte", sans-serif
    
body
    font-family: $second-family
    font-weight: 400
    font-size: 20px
    color: #6e6a63
    background: #f8f6f2
    line-height: 1.2

h2
    font-size: 64px

.container
    max-width: 1300px
    margin: 0 auto
    padding: 0 20px
    box-sizing: content-box

.btn__blc
    border-radius: 32px
    background: #151515
    padding: 11px 30px
    font-family: $second-family
    font-weight: 500
    font-size: 16px
    color: #f7f5f1
    transition: all .3s
    border: none
    display: block
    width: max-content
    &:hover
        background: #6e6a63

.nav
    background: #f8f6f2
    padding: 23px 0
    &__hum
        display: none
    .container
        display: flex
        justify-content: start
        align-items: center
    &__list
        margin: 0 auto
        display: flex
        justify-content: center
        align-items: center
        gap: 50px
        a
            font-family: $second-family
            font-weight: 500
            font-size: 16px
            color: #2a2a2a
            transition: all .3s
            &:hover
                color: #6e6a63
    &__logo
        font-family: $font-family
        font-weight: 400
        font-size: 32px
        color: #2a2a2a

.header
    padding: 290px 0 180px
    background: url('../img/header_bg.jpg') center no-repeat    
    background-size: cover
    z-index: 2
    position: relative
    overflow: hidden
    &::before
        content: ''
        display: block
        z-index: -1
        left: 80px
        right: 80px
        top: 120px
        bottom: 240px
        position: absolute
        filter: blur(200px)
        background: rgba(0, 0, 0, 0.5)
    h1
        font-family: $font-family
        font-weight: 400
        font-size: 96px
        text-align: center
        color: #fff
    p
        margin: -24px 0 0
        font-family: $font-family
        font-weight: 400
        font-size: 40px
        color: #fff
        text-align: center
    &__link
        display: block
        width: max-content
        margin: 156px auto 0
        font-family: $second-family
        font-weight: 500
        font-size: 24px
        color: #fff
        transition: all .3s
        &:hover
            opacity: .7

.about
    padding: 100px 0 60px
    h2
        font-family: $font-family
        font-weight: 400
        text-transform: uppercase
        color: #2a2a2a
    &__wrapper
        margin: 55px 0 0
        display: grid
        grid-template-columns: 1fr 591px
        gap: 50px
    &__text
        max-width: 440px
        p
            font-family: $second-family
            font-weight: 400
            font-size: 20px
            color: #6e6a63
        div
            margin: 0 0 100px
        .btn__blc
            font-size: 20px
            padding: 14px 43px
    &__bg
        display: block
        width: 100%
        border-radius: 32px

.service
    background: #151515
    padding: 100px 0 50px
    position: relative
    overflow: hidden
    &__wrapper
        display: grid
        grid-template-columns: 1fr 709px
        gap: 30px
        align-items: start
    h2
        font-family: $font-family
        font-weight: 400
        text-transform: uppercase
        color: #fff
    &__list
        display: grid
        grid-template-columns: 1fr
        gap: 25px
    &__info
        display: none
        grid-template-columns: 1fr
        gap: 20px
    &__text
        display: grid
        grid-template-columns: 1fr auto
        gap: 50px
        p
            font-family: $font-family
            font-weight: 400
            font-size: 24px
            text-transform: lowercase
            color: #fff
            &+p
                font-family: $second-family
                font-weight: 200
                font-size: 16px
                text-transform: lowercase
                color: #fff
        div
            max-width: 580px
            &+p
                font-family: $third-family
                font-weight: 300
                font-size: 20px
                text-transform: lowercase
                color: #fff
    &__btn
        display: grid
        grid-template-columns: 1fr auto
        gap: 10px
        align-items: center
        cursor: pointer
        padding: 25px 0 0
        border-top: 1px solid #fff
        p
            font-family: $font-family
            font-weight: 400
            font-size: 36px
            text-transform: uppercase
            color: #fff
            line-height: 1
        span
            &::before
                content: '+'
                display: block
                font-family: $second-family
                font-weight: 400
                font-size: 36px
                text-transform: uppercase
                color: #fff
                line-height: 1
        &.active
            span
                &::before
                    content: '-'
            &+.service__info
                display: grid
    &__sale
        margin: 100px 0 0
        position: relative
        width: 100vw
        left: 50%
        transform: translateX(-50%)
        padding: 20px
        background: #f8f6f2
        p
            font-family: $font-family
            font-weight: 700
            font-size: 32px
            text-transform: uppercase
            color: #000
            text-align: center

.port
    padding: 100px 0 0
    position: relative
    overflow: hidden
    h2
        font-family: $font-family
        font-weight: 400
        text-transform: uppercase
        color: #2a2a2a
    &__wrapper
        margin: 55px 0 0
        display: grid
        grid-template-columns: 1fr 1fr 1fr 1fr
        gap: 40px
        row-gap: 55px
        position: relative
    &__item
        p
            font-family: $font-family
            font-weight: 400
            font-size: 32px
            text-transform: uppercase
            color: #000
            margin: 10px 0 0
        img
            width: 100%
            border-radius: 32px
            height: 292px
            object-fit: cover
        &_width
            grid-column: span 2
        &.active
            .port
                &__modal
                    opacity: 1
                    pointer-events: auto
    &__link
        margin: 125px 0 0
        display: block
        position: relative
        width: 100vw
        left: 50%
        transform: translateX(-50%)
        background: #151515
        padding: 28px
        font-family: $font-family
        font-weight: 400
        font-size: 64px
        text-transform: uppercase
        color: #fff
        text-align: center
    &__modal
        position: absolute
        top: -135px
        bottom: -32px
        left: 50px
        right: 50px
        display: grid
        grid-template-columns: 1fr 1fr 1fr 1fr
        gap: 36px
        overflow: auto
        padding: 96px
        background: rgba(21, 21, 21, 0.8)
        opacity: 0
        pointer-events: none
        img
            height: 200px

.team
    padding: 100px 0 
    h2
        font-family: $font-family
        font-weight: 400
        text-transform: uppercase
        color: #2a2a2a
    &__wrapper
        display: grid
        grid-template-columns: 1fr 1fr 1fr 1fr
        gap: 55px
        margin: 55px 0 0
    &__item
        img
            width: 100%
            height: 371px
            object-fit: cover
            border-radius: 32px
        p
            margin: 10px 0 0
            font-family: $font-family
            font-weight: 400
            font-size: 24px
            text-transform: capitalize
            color: #000
            &+p
                margin: 0
                font-family: $font-family
                font-weight: 400
                font-size: 20px
                text-transform: capitalize
                color: #6e6a63
    &__link
        margin: 55px auto 0

.comment
    padding: 100px 0
    background: #151515
    position: relative
    overflow: hidden
    .swiper-slide
        border-radius: 25px
        padding: 32px 20px
        background: #f8f6f2
        width: calc( (100vw - 60px) / 2 )
        max-width: 640px
    &__wrapper
        margin: 55px 0 0
        position: relative
        overflow: visible
    h2
        font-family: $font-family
        font-weight: 400
        text-transform: uppercase
        color: #fff
    &__row
        display: grid
        grid-template-columns: 1fr auto
        align-items: center
        gap: 55px
    &__arrow
        position: relative
        display: flex
        justify-content: center
        align-items: center
        gap: 22px
        .swiper-button-prev,
        .swiper-button-next
            display: flex
            justify-content: center
            align-items: center
            border: none
            position: relative !important
            inset: auto !important
            margin: 0 !important
            transform: none !important
            width: 84px
            height: 39px
            border-radius: 32px
            background: #f8f6f2
            transition: all .3s
            svg
                width: 44px
                height: 15px
    p
        &.text
            font-family: $second-family
            font-weight: 400
            font-size: 20px
            color: #000
            margin: 32px 0 0
        &.name
            font-family: $font-family
            font-weight: 400
            font-size: 24px
            color: #000
            margin: 0 0 32px
    .star
        display: flex
        justify-content: start
        align-items: center

.contact
    padding: 100px 0
    h2
        font-family: $font-family
        font-weight: 400
        text-transform: uppercase
        color: #2a2a2a
    &__wrapper
        display: grid
        grid-template-columns: 1fr 590px
        gap: 50px
        align-items: start
        margin: 55px 0 0
        ul
            display: grid
            grid-template-columns: 1fr
            gap: 25px
        p
            font-family: $second-family
            font-weight: 400
            font-size: 20px
            color: #000
            span
                font-family: $font-family
                font-weight: 700
        img
            border: 2px solid #000
            border-radius: 32px
            width: 100%

.footer
    padding: 20px 0 60px
    background: #151515
    position: relative
    overflow: hidden
    .container
        display: flex
        justify-content: space-between
        align-items: start
    ul
        display: grid
        grid-template-columns: 1fr
        gap: 10px
    a
        font-family: $second-family
        font-weight: 400
        font-size: 16px
        color: #f8f6f2
        transition: all .3s
        &:hover
            color: #6e6a63

@media ( max-width: 1300px )
    h2
        font-size: 48px
    .nav
        &__list
            gap: 20px
    .header
        padding: 200px 0 150px
        &__link
            margin: 120px auto 0
    .port
        &__item
            p
                font-size: 24px
        &__link
            font-size: 48px
    .team
        &__wrapper
            gap: 20px

@media ( max-width: 1024px )
    .nav
        padding: 18px 0
        .container
            display: grid
            grid-template-columns: 1fr auto
        &__list,
        .btn__blc
            display: none
        &__logo
            font-size: 24px
        &__hum
            height: 16px
            width: 30px
            display: block
            position: relative
            cursor: pointer
            span,
            &::before,
            &::after
                content: ''
                display: block
                width: 100%
                height: 2px
                background: #2a2a2a
                position: absolute
                top: 0
                left: 0
            &::before
                top: 50%
                transform: translateY(-50%)
            &::after
                bottom: 0
                top: auto
        &.active
            position: fixed
            height: 100vh
            max-height: 100%
            top: 0
            left: 0
            z-index: 100
            width: 100%
            overflow: auto
            display: grid
            .container
                height: 100%
                display: grid
                grid-template-rows: auto 1fr auto
                width: 100%
                box-sizing: border-box
            .btn__blc
                display: block
                margin: 0 auto
                grid-column: 1/3
            .nav
                &__list
                    grid-column: 1/3
                    display: grid
                    grid-template-columns: 1fr
                    gap: 10px
                    text-align: center
                    margin: auto 0
    .header
        padding: 120px 0
        h1
            font-size: 68px
        p
            font-size: 32px
            margin: -19px 0 0
        &__link
            font-size: 18px
            margin: 80px auto 0
    .about
        padding-top: 80px
        &__wrapper
            grid-template-columns: 1fr 1fr
    .service
        padding: 80px 0 20px
        &__wrapper
            grid-template-columns: auto 1fr
            gap: 50px
    .port
        padding: 80px 0 0
        &__wrapper
            margin: 30px 0 0
            grid-template-columns: 1fr 1fr
        &__link
            font-size: 36px
            margin: 55px 0 0
    .team
        padding: 80px 0 
        &__wrapper
            grid-template-columns: 1fr 1fr 1fr
    .contact
        padding: 80px 0
        &__wrapper
            grid-template-columns: 1fr 1fr
    .comment
        padding: 80px 0

@media ( max-width: 768px )
    h2
        font-size: 36px
    .about
        &__wrapper
            grid-template-columns: 1fr
        &__text
            div
                margin: 0 0 55px
    .service
        &__wrapper
            grid-template-columns: 1fr
        &__btn
            p
                font-size: 24px
            span
                &::before
                    font-size: 24px
        &__sale
            margin: 50px 0 0
            p
                font-size: 24px
    .port
        &__item
            img
                height: 230px
            p
                font-size: 18px
        &__wrapper
            gap: 20px
    .team
        &__wrapper
            grid-template-columns: 1fr 1fr
    .comment
        .swiper-slide
            width: calc( 100vw - 40px )
        &__wrapper
            margin: 30px 0 0
    .contact
        padding: 60px 0 
        &__wrapper
            grid-template-columns: 1fr
    .footer
        .container
            display: grid
            grid-template-columns: 1fr
            gap: 50px

@media ( max-width: 500px )
    h2
        font-size: 28px
    .header
        h1
            font-size: 40px
        p
            font-size: 24px
            margin: 0px 0 0
    .service
        &__text
            grid-template-columns: 1fr
            gap: 5px
    .port
        &__wrapper
            grid-template-columns: 1fr
        &__item
            grid-column: auto
    .team
        &__wrapper
            grid-template-columns: 1fr
    .comment
        &__arrow
            display: none








