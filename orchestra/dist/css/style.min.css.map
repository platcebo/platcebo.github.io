body
    font-family: "Montserrat", sans-serif
    position: relative
    color: #fff
    line-height: 1.3

header,
section
    background-position: center
    background-size: cover
section
    margin: -2px 0 0

.container
    padding: 0 100px
    margin: 0 auto

.nav
    display: flex
    justify-content: space-between
    align-items: center
    gap: 20px
    img
        width: 100%
        max-width: 335px
        display: block
    &__lang
        position: relative
        div
            border-radius: 10px
            border: 1px solid #fff
            padding: 5px 10px
            display: flex
            justify-content: start
            align-items: center
            gap: 6px
            width: 90px
        a
            display: flex
            justify-content: start
            align-items: center
            gap: 6px
            // p
            //     color: #fff
        ul
            display: none
            position: absolute
            top: 100%
            left: 0
            grid-template-columns: 1fr
            gap: 10px
            border-radius: 5px
            border: 1px solid #fff
            padding: 10px
            width: 90px
        img
            width: 26px
            display: block
        p
            font-size: 20px
            color: #fff
            text-transform: uppercase
        &:hover
            ul
                display: grid

.header
    padding: 40px 0 0
    &__container
        margin: 40px 0 0
        display: grid
        grid-template-columns: 1fr 1fr
        gap: 100px
        align-items: center
    &__bg
        margin: 0 0 0 0
        display: block
        width: 100%
        object-fit: cover
    &__info
        max-width: 900px
    &__date,
    &__text
        font-size: 18px
        font-weight: 300
        gap: 30px
        max-width: 370px
        span
            font-weight: 500
    h1
        font-size: 60px
        font-weight: 600
        color: #FFBB57
        margin: 30px 0
        span
            color: #fff
    .map__btn
        margin: 30px 0 0

.pop
    padding: 40px 0 100px
    &__container
        margin: 40px 0 0
        display: grid
        grid-template-columns: 1fr 1fr
        gap: 100px
        align-items: center
    &__bg
        width: 100%
    &__info
        img
            mix-blend-mode: lighten
            display: block
            max-width: 440px
            width: 100%
            margin: 0 auto 30px
    &__text
        font-size: 18px
        font-weight: 300
    &__har
        display: flex
        justify-content: center
        align-items: center
        margin: 40px 0 0
        gap: 20px
        div
            width: 120px
            height: 120px
            display: flex
            justify-content: center
            align-items: center
            flex-direction: column
            border-radius: 100%
            border: 3px solid #FFBB57
            gap: 5px
        p
            font-size: 24px
            font-weight: 500
            &+p
                font-size: 18px
                font-weight: 300

.gal
    padding: 40px 0 0
    &__wrapper
        display: grid
        grid-template-columns: 1fr 1fr 1fr
        gap: 10px
        img
            width: 100%
            height: 100%
            object-fit: cover

.program
    padding: 100px 0 
    h2
        font-size: 60px
        text-align: center
        margin: 0 0 30px
    &__tab
        display: flex
        justify-content: start
        align-items: center
        li
            cursor: pointer
            font-size: 20px
            padding: 20px 30px
            background: #ffffff89
            color: #000
            transition: all .3s
            &.active,
            &:hover
                background: #fff
    &__wrapper
        padding: 20px 
        border: 2px solid #fff
        display: none
        &.active
            display: block
    &__text
        font-size: 18px
    &__instrumet
        display: flex
        justify-content: center
        align-items: center
        gap: 20px
        margin: 30px 0 0
        flex-wrap: wrap
        p
            font-size: 24px
            font-weight: 500
        img
            width: 130px
            height: 130px
            border-radius: 100%
            display: block
            object-fit: cover

.guests
    padding: 50px 0
    h2
        font-size: 60px
        text-align: center
        color: #FFBB57
    &__wrapper
        display: grid
        grid-template-columns: 1fr 1fr 1fr
        gap: 20px
        margin: 40px auto 0
        max-width: 960px
        img,
        video
            width: 100%
            height: 100%
            object-fit: cover

.map
    padding: 50px 0
    text-align: center
    h2
        font-size: 60px
        text-align: center
        color: #FFBB57
    &__place
        margin: 30px 0 0
        p
            font-size: 24px
            font-weight: 500
            &+p
                font-size: 18px
                margin: 20px 0 0
                font-weight: 300
    &__wrapper
        max-width: 1200px
        margin: 30px auto 0
        iframe
            width: 100%
            height: 500px
    &__date
        margin: 30px 0 0
        font-size: 24px
        font-weight: 500
        span
            font-weight: 300
    &__btn
        margin: 30px auto 0
        max-width: max-content
        padding: 15px 70px
        font-size: 18px
        color: #000
        background: #FFBB57
        transition: all .3s
        border: none
        display: block
        &:hover
            background: #ffbc57ab

.footer
    padding: 50px 0
    background: linear-gradient(180deg, #0a0e1f 0%, rgba(10, 14, 31, 0) 100%)
    background-position: center
    background-size: cover
    margin: -2px 0 0
    &__logo
        max-width: 220px
        margin: 0 auto
        display: block
    &__soc
        display: flex
        justify-content: center
        align-items: center
        gap: 20px
        margin: 30px 0 0
        svg
            width: 30px
            height: 30px
            path
                fill: #fff
    &__lang
        display: flex
        justify-content: center
        align-items: center
        gap: 40px
        margin: 30px 0 0
        a
            display: flex
            justify-content: start
            align-items: center
            gap: 6px
        img
            width: 26px
            display: block
        p
            font-size: 18px
            color: #fff
            text-transform: uppercase


.ticket
    padding: 60px 0 0
    &__wrapper
        display: flex
        justify-content: center
        align-items: center
        gap: 30px
        flex-wrap: wrap
    &__item
        max-width: 500px
        width: 100%
        padding: 20px 
        display: block
        border: 1px solid #fff
        .map__btn
            margin: 0 0 0
            width: 100%
            padding: 15px
            max-width: 250px
            text-align: center
    &__date
        font-size: 18px
        color: #fff
    &__name
        margin: 15px 0 0
        p
            font-size: 24px
            color: #FFBB57
            font-weight: 600
            &+p
                font-weight: 300
                font-size: 20px
                color: #fff
                margin: 5px 0 0
    &__row
        display: grid
        grid-template-columns: 1fr 1fr
        margin: 20px 0 0
        gap: 20px
    &__btn
        max-width: max-content
        padding: 15px
        max-width: 250px
        text-align: center
        font-size: 18px
        color: #FFBB57
        background: transparent
        transition: all .3s
        border: none
        display: block
        border: 1px solid #FFBB57
        &:hover
            color: #fff
            border-color: #fff

.comment
    padding: 40px 0
    &__wrapper
        max-width: 1000px
        margin: 0 auto
        padding: 0 0 40px
        img
            width: 100%
            height: 100%
    .swiper-pagination
        span
            background: #FFBB57
            bottom: -40px
            top: auto
            transform: none
            margin: 0

.form
    .wpcf7-form-control-wrap
        position: static !important
    h2
        font-size: 60px
        text-align: center
        color: #FFBB57
    &__wrapper
        margin: 30px auto 0
        display: grid
        grid-template-columns: 1fr 1fr 1fr
        max-width: 1200px
        gap: 30px
        input
            border: 1px solid #FFBB57
            padding: 10px 15px
            font-size: 20px
            color: #fff
            font-size: 18px
            background: transparent
            width: 100%
            box-sizing: border-box
        textarea
            grid-column: 1/4
            border: 1px solid #FFBB57
            padding: 10px 15px
            font-size: 20px
            color: #fff
            font-size: 18px
            background: transparent
            resize: none
            height: 120px
            width: 100%
            box-sizing: border-box
    .wpcf7-form-control-wrap
        &:nth-child(5)
            grid-column: 1/4
    &__select
        position: relative
        grid-column: 1/4
        z-index: 1
        p
            border: 1px solid #FFBB57
            padding: 10px 15px
            font-size: 18px
        svg
            position: absolute
            right: 10px
            top: 50%
            transform: translateY(-50%)
            width: 12px
            height: 12px
        select
            position: absolute
            top: 0
            left: 0
            width: 100%
            height: 100%
            opacity: 0
            z-index: 10
    &__check
        grid-column: 1/4
        display: grid
        grid-template-columns: 18px 1fr
        gap: 15px
        align-items: center
        position: relative
        span.wpcf7-form-control-wrap
            position: absolute !important
        b
            width: 18px
            height: 18px
            display: flex
            justify-content: center
            border: 1px solid #FFBB57
            svg
                opacity: 0
                transition: all .3s
        p
            color: #fff
            font-size: 18px
        a
            color: #fff
            text-decoration: underline
            transform: all .3s
            &:hover
                opacity: .7
        input
            position: absolute
            left: 0
            opacity: 0
            &:checked
                &+b
                    svg
                        opacity: 1
        &:has(input:checked)
            b
                svg
                    opacity: 1
    input.map__btn
        margin: 0
        max-width: max-content
        padding: 15px 70px
        font-size: 18px
        color: #000
        background: #FFBB57
        transition: all .3s
        border: none
        display: block
        &:hover
            background: #ffbc57ab







@media ( max-width: 1500px )
    .container
        padding: 0 50px
    .header
        h1
            font-size: 40px

@media ( max-width: 1024px )
    .container
        padding: 0 20px
    .nav
        img
            max-width: 320px
    .header
        &__container
            grid-template-columns: 1fr
            gap: 30px
        &__bg
            margin: 0 -20px
            width: calc( 100% + 40px )
            order: -1
    .pop
        &__container
            grid-template-columns: 1fr
            gap: 30px
    .gal
        padding-bottom: 50px
    .program
        padding: 50px 0
        h2
            font-size: 35px
        &__tab
            li
                font-size: 18px
                padding: 15px 20px
        &__instrumet
            p
                width: 100%
                text-align: center
            img
                width: 90px
                height: 90px
    .guests,
    .map,
    .form
        h2
            font-size: 35px

@media ( max-width: 800px )
    .form
        &__wrapper
            grid-template-columns: 1fr
            textarea
                grid-column: auto
        &__select,
        &__check
            grid-column: auto
        .wpcf7-form-control-wrap
            &:nth-child(5)
                grid-column: auto   
    
@media ( max-width: 600px )
    .nav
        img
            max-width: 200px
        &__lang
            div,
            ul
                padding: 5px
                width: 70px
            p
                font-size: 17px
    .header
        h1
            font-size: 28px
    .pop
        padding-bottom: 50px
        &__info
            img
                max-width: 220px
    .gal
        &__wrapper
            grid-template-columns: 1fr 1fr
    .program
        h2
            font-size: 28px
        &__tab
            display: grid
            grid-template-columns: 1fr 1fr
            li
                white-space: nowrap
                overflow: hidden
                text-overflow: ellipsis
                display: block
                position: relative
        &__instrumet
            column-gap: 10px
            img
                width: 50px
                height: 50px
    .guests,
    .map
        h2
            font-size: 28px
    .guests
        &__wrapper
            margin: 28px 0 0
    .ticket
        &__row
            display: grid
            grid-template-columns: 1fr
