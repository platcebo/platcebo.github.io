body
    font-family: "Montserrat", sans-serif
    position: relative
    color: #fff
    line-height: 1.3

header,
section
    background-position: center
    background-size: cover
section
    margin: -2px 0 0

.container
    padding: 0 100px
    margin: 0 auto

.nav
    display: flex
    justify-content: space-between
    align-items: center
    gap: 20px
    img
        width: 100%
        max-width: 420px
        display: block
    &__lang
        position: relative
        div
            border-radius: 10px
            border: 1px solid #fff
            padding: 5px 10px
            display: flex
            justify-content: start
            align-items: center
            gap: 6px
            width: 90px
        a
            display: flex
            justify-content: start
            align-items: center
            gap: 6px
            // p
            //     color: #fff
        ul
            display: none
            position: absolute
            top: 100%
            left: 0
            grid-template-columns: 1fr
            gap: 10px
            border-radius: 5px
            border: 1px solid #fff
            padding: 10px
            width: 90px
        img
            width: 26px
            display: block
        p
            font-size: 20px
            color: #fff
            text-transform: uppercase
        &:hover
            ul
                display: grid

.header
    padding: 40px 0 0
    &__container
        margin: 40px 0 0
        display: grid
        grid-template-columns: 1fr 1fr
        gap: 100px
        align-items: center
    &__bg
        margin: 0 -100px 0 0
        display: block
        width: calc( 100% + 100px )
        object-fit: cover
    &__info
        max-width: 900px
    &__date,
    &__text
        font-size: 18px
        font-weight: 300
        gap: 30px
        max-width: 370px
        span
            font-weight: 500
    h1
        font-size: 60px
        font-weight: 600
        color: #FFBB57
        margin: 30px 0
        span
            color: #fff

.pop
    padding: 40px 0 100px
    &__container
        margin: 40px 0 0
        display: grid
        grid-template-columns: 1fr 1fr
        gap: 100px
        align-items: center
    &__bg
        width: 100%
    &__info
        img
            mix-blend-mode: lighten
            display: block
            max-width: 440px
            margin: 0 auto 30px
    &__text
        font-size: 18px
        font-weight: 300
    &__har
        display: flex
        justify-content: center
        align-items: center
        margin: 40px 0 0
        gap: 20px
        div
            width: 120px
            height: 120px
            display: flex
            justify-content: center
            align-items: center
            flex-direction: column
            border-radius: 100%
            border: 3px solid #FFBB57
            gap: 5px
        p
            font-size: 24px
            font-weight: 500
            &+p
                font-size: 18px
                font-weight: 300

.gal
    padding: 40px 0 100px
    &__wrapper
        display: grid
        grid-template-columns: 1fr 1fr 1fr
        gap: 10px
        img
            width: 100%
            height: 100%
            object-fit: cover

.program
    padding: 100px 0 
    h2
        font-size: 60px
        text-align: center
        margin: 0 0 30px
    &__tab
        display: flex
        justify-content: start
        align-items: center
        li
            cursor: pointer
            font-size: 20px
            padding: 20px 30px
            background: #ffffff89
            color: #000
            transition: all .3s
            &.active,
            &:hover
                background: #fff
    &__wrapper
        padding: 20px 
        border: 2px solid #fff
        display: none
        &.active
            display: block
    &__text
        font-size: 18px
    &__instrumet
        display: flex
        justify-content: center
        align-items: center
        gap: 20px
        margin: 30px 0 0
        flex-wrap: wrap
        p
            font-size: 24px
            font-weight: 500
        img
            width: 130px
            height: 130px
            border-radius: 100%
            display: block
            object-fit: cover

.guests
    padding: 50px 0
    h2
        font-size: 60px
        text-align: center
        color: #FFBB57
    &__wrapper
        display: grid
        grid-template-columns: 1fr 1fr 1fr
        gap: 20px
        margin: 40px auto 0
        max-width: 960px
        img,
        video
            width: 100%
            height: 100%
            object-fit: cover

.map
    padding: 50px 0
    text-align: center
    h2
        font-size: 60px
        text-align: center
        color: #FFBB57
    &__place
        margin: 30px 0 0
        p
            font-size: 24px
            font-weight: 500
            &+p
                font-size: 18px
                margin: 20px 0 0
                font-weight: 300
    &__wrapper
        max-width: 1200px
        margin: 30px auto 0
        iframe
            width: 100%
            height: 500px
    &__date
        margin: 30px 0 0
        font-size: 24px
        font-weight: 500
        span
            font-weight: 300
    &__btn
        margin: 30px auto 0
        max-width: max-content
        padding: 15px 70px
        font-size: 18px
        color: #000
        background: #FFBB57
        transition: all .3s
        border: none
        display: block
        &:hover
            background: #ffbc57ab

.footer
    padding: 50px 0
    background: linear-gradient(180deg, #0a0e1f 0%, rgba(10, 14, 31, 0) 100%)
    background-position: center
    background-size: cover
    margin: -2px 0 0
    &__logo
        max-width: 220px
        margin: 0 auto
        display: block
    &__soc
        display: flex
        justify-content: center
        align-items: center
        gap: 20px
        margin: 30px 0 0
        svg
            width: 30px
            height: 30px
            path
                fill: #fff

