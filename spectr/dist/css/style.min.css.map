.step
    .title
        max-width: calc( 100% - 135px )
        position: relative  
    .container
        position: relative
    &__slider
        margin: 50px 0 0
        position: relative
        counter-reset: step
    .swiper
        &-pagination
            display: none
        &-wrapper
            align-items: stretch
    &__arrow
        position: absolute
        top: 0
        right: 20px
        display: grid
        grid-template-columns: 1fr 1fr
        gap: 0
        .swiper-button-next,
        .swiper-button-prev
            position: relative
            inset: auto
            margin: 0
            transform: none
            display: flex
            justify-content: center
            align-items: center
            border: 1px solid #d4d2cc
            width: 68px
            height: 68px
            svg
                width: 32px
                height: 32px
            path
                fill: transparent
                stroke: $new-color---black
