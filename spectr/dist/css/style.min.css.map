$color---arrow: #b5b5b5
$color---icon-header: #b0afa2
$color---text-header: #858279
$color---green: #58d97c
$stroke---devider-card: #d7d3c7
$bg---field-form: #fcfcf6
$button---hover: #79624b
$new-color---white: #fff
$new-color---text: #636057
$new-color---black: #1a1a1a
$new-color---main: #8d765f
$new-color---policy: #918d81
$new-color---point-fill: #eeeadd
$new-input---inactive: #b7b7b7
$new-bg---main: #f2f0ea
$new-bg---card: #e7e2d6
$new-bg---map: #fdfcf9
$new-bg---1-screen: #fdfcf9
$new-bg---header-up: #f7f6f3
$new-bg---header-down: #fefefd
$new-stroke---main: #dddbd5
$new-stroke---accent: #9d8975
$new-stroke---icon: #b9b5a9
$new-stroke---point: #918e85
$new-footer---category-title: #918d81
$new-footer---separator: #c3bfb3
$old-black: #2e2e2e
$old-card-line: #d1cec5
$old-icon-line: #b8b7ae
$old-text-light: #8c8a79
$old-text-dark: #504d44
$old-policy: #9c988d
$old-footer-descriptors: #8f8677
$old-bg: #efece3

$font-family: "Inter", sans-serif
$second-family: "PP Neue Montreal", sans-serif
$third-family: "Source Serif 4", sans-serif
$font3: "Evolventa", sans-serif
$font4: "Proxima Nova", sans-serif
$font5: "TT Norms", sans-serif
$font6: "Arial", sans-serif

body
    background: $new-bg---main
    font-family: $font-family
    // font-size: calc( 100vw / 1920 )

.container
    max-width: 1200px
    padding: 0 20px
    margin: 0 auto
    box-sizing: content-box

.btn
    &__brown
        font-family: $font-family
        font-weight: 500
        font-size: 20px
        line-height: 1
        text-align: center
        color: $new-color---white
        position: relative
        transition: all .3s
        border-radius: 5px
        padding: 25px 35px
        background: $new-color---main
        border: none
        overflow: hidden
        min-width: 220px
        span
            transition: all .3s
            display: block
            &:nth-child(2)
                width: 100%
                position: absolute
                top: 50%
                left: 50%
                transform: translate(-50%,70px)
        &:hover
            background: $button---hover
            span
                &:nth-child(1)
                    transform: translateY(-70px)
                &:nth-child(2)
                    transform: translate(-50%,-50%)
    &__gray
        font-family: $font-family
        font-weight: 500
        font-size: 20px
        line-height: 1
        text-align: center
        color: #000
        position: relative
        transition: all .3s
        border-radius: 5px
        padding: 24px 34px
        background: transparent
        border: 1px solid $new-stroke---main
        overflow: hidden
        min-width: 220px
        span
            transition: all .3s
            display: block
            &:nth-child(2)
                width: 100%
                position: absolute
                top: 50%
                left: 50%
                transform: translate(-50%,70px)
        &:hover
            background: $button---hover
            border: 1px solid $button---hover
            color: $new-color---white
            span
                &:nth-child(1)
                    transform: translateY(-70px)
                &:nth-child(2)
                    transform: translate(-50%,-50%)

.title
    h2
        font-family: $font3
        font-weight: 400
        font-size: 60px
        line-height: 1.2
        letter-spacing: 0.02em
        color: #000
    p
        max-width: 410px
        margin: 20px 0 0
        font-family: $font-family
        font-weight: 400
        font-size: 20px
        line-height: 1.5
        color: $new-color---text

.title__anim
    opacity: 0
    transform: translateY(40px)
    transition: all 0.8s ease
    h2 
        opacity: 0
        transform: translateY(20px)
        transition: all 0.6s ease 0.2s
    p 
        span 
            display: inline-block
            opacity: 0
            transform: translateY(20px)
            transition: all 0.6s ease
            &:nth-child(1)  
                transition-delay: 0.4s 
            &:nth-child(2)  
                transition-delay: 0.6s 
            &:nth-child(3)  
                transition-delay: 0.8s 
    &.is-visible 
        opacity: 1
        transform: translateY(0)
        h2 
            opacity: 1
            transform: translateY(0)
        p span 
            opacity: 1
            transform: translateY(0)
    
.nav
    position: sticky
    top: -100%
    z-index: 5
    transition: all .4s
    &.active
        top: 0
    &__hum
        display: none
    &-info
        background: $new-bg---header-up
        padding: 17px 0
        .container
            display: flex
            justify-content: start
            align-items: center
            gap: 35px
        &__info
            display: grid
            grid-template-columns: 16px 1fr
            gap: 8px
            align-items: center
        p
            font-family: $font-family
            font-weight: 400
            font-size: 15px
            line-height: 1.3
            color: $color---text-header
            transition: all .3s
        path
            transition: all .3s
            fill: $color---text-header
        .modal__call
            margin: 0 0 0 auto
            cursor: pointer
        .modal__call,
        a
            &:hover
                path,
                p
                    fill: $new-color---main
                    color: $new-color---main
    &__container
        padding: 20px 0
        background: $new-bg---header-down
        position: relative
        .container
            gap: 20px
            display: flex
            justify-content: start
            align-items: center
    &__logo
        max-width: 178px
        display: block
        img
            width: 100%
        svg
            width: 100%
        path
            transition: all .3s
        &:hover
            path
                fill: $button---hover
    &__list
        margin: 0 auto
        display: flex
        justify-content: start
        align-items: center
        gap: 35px
    &__link
        a
            font-family: $font-family
            font-weight: 400
            font-size: 18px
            line-height: 1.3
            color: #000
            transition: all .3s
            &:hover
                color: $new-color---main
    &__phone
        display: grid
        grid-template-columns: 1fr 8px
        gap: 12px
        align-items: center
        span
            display: block
            width: 8px
            height: 8px
            border-radius: 100%
            background: #58D97C
        p
            font-family: $font-family
            font-weight: 400
            font-size: 18px
            line-height: 1.3
            color: #000
            transition: all .3s
            &:hover
                color: $new-color---main
    &-dop
        &__btn
            display: grid
            grid-template-columns: 1fr 9px
            gap: 7px
            align-items: center
            cursor: pointer
            p
                font-family: $font-family
                font-weight: 400
                font-size: 18px
                line-height: 1.3
                color: #000
                transition: all .3s
                &:hover
                    color: $new-color---main
            svg
                transition: all .3s
        &__wrapper
            position: absolute
            left: 0
            width: 100%
            top: 100%
            background: $new-bg---header-down
            display: none
            padding: 30px 0 60px
            z-index: 5
            .container
                display: grid
                grid-template-columns: 337px 337px 1fr
                gap: 20px
                align-items: flex-start !important
            ul
                display: grid
                grid-template-columns: 1fr
                gap: 25px
            a
                font-family: $second-family
                font-weight: 500
                font-size: 28px
                line-height: 1.2
                transition: all .3s
                color: #000
                &:hover
                    color: $new-color---main
            img
                width: 100%
                max-width: 292px
                margin: 0 0 0 auto
                display: block
                border-radius: 5px
        &.active
            .nav-dop
                &__wrapper
                    display: block
                &__btn
                    p
                        color: $new-color---main
                    svg
                        transform: rotate(180deg)

.header
    padding: 120px 0 184px
    position: relative
    overflow: hidden
    background: $new-bg---header-down
    z-index: 2
    .container
        position: relative
    &__info
        h1
            font-family: $font3
            font-weight: 400
            font-size: 65px
            line-height: 1.2
            letter-spacing: 0.02em
            color: #000
            max-width: 700px
        p
            margin: 25px 0 0
            font-family: $font-family
            font-weight: 400
            font-size: 20px
            line-height: 1.5
            color: $new-color---text
            max-width: 410px
        .btn__brown
            margin: 35px 0 0
    &__bg
        position: absolute
        right: -230px
        width: 1174px
        bottom: -184px
        z-index: -1
        img
            width: 100%
        div
            position: absolute
            right: 250px
            bottom: 116px
            border-radius: 5px
            padding: 18px 20px 15px
            background: $new-color---white
            p
                font-family: $font-family
                font-weight: 500
                font-size: 20px
                line-height: 1
                color: #000
                &+p
                    margin: 5px 0 0
                    font-family: $font-family
                    font-weight: 400
                    font-size: 20px
                    line-height: 1.5
                    color: $new-stroke---point

.service
    padding: 180px 0 0
    &__wrapper
        display: grid
        grid-template-columns: 1fr 1fr 1fr
        gap: 10px
        margin: 50px 0 0
    &__item
        min-height: 280px
        border-radius: 5px
        transition: all .3s
        display: grid
        grid-template-columns: 1fr 20px
        gap: 10px
        background: $new-bg---card
        padding: 25px
        p
            font-family: $second-family
            font-weight: 500
            font-size: 28px
            line-height: 1.2
            color: #000
            transition: all .3s
        span
            margin: 6px 0 0
            display: block
        path
            transition: all .3s
        &:hover
            background: $new-color---main
            p
                color: $new-color---white
            path
                stroke: $new-color---white

.input
    &__text
        border-radius: 5px
        padding: 23px 25px
        width: 100%
        box-sizing: border-box
        background: $new-color---white
        font-family: $font-family
        font-weight: 500
        font-size: 20px
        line-height: 1
        color: #000
        border: none
        &::placeholder
            color: $new-input---inactive
    &__select
        position: relative
        input
            border-radius: 5px
            padding: 23px 25px
            width: 100%
            box-sizing: border-box
            background: $new-color---white
            font-family: $font-family
            font-weight: 500
            font-size: 20px
            line-height: 1
            color: #000
            border: none
            cursor: pointer
            &::placeholder
                color: $new-input---inactive
        svg
            right: 25px
            top: 50%
            transform: translateY(-50%)
            position: absolute
        ul
            position: absolute
            z-index: 2
            left: 0
            top: 100%
            width: 100%
            display: none
            li
                font-family: $font-family
                font-weight: 500
                font-size: 20px
                line-height: 1
                color: #000
                background: $new-color---white
                padding: 23px 25px
                transition: all .3s
                cursor: pointer
                &:hover
                    background: $new-bg---main
        &.active
            ul
                display: block
            input
                border-radius: 5px 5px 0 0
    &__check
        display: grid
        grid-template-columns: 20px 1fr
        gap: 10px
        align-items: start
        position: relative
        span.wpcf7-form-control-wrap
            position: absolute !important
        b
            border: 1px solid $new-color---main
            border-radius: 4px
            width: 20px
            height: 20px
            display: flex
            justify-content: center
            align-items: center
            &::before
                content: ''
                display: block
                opacity: 0
                transition: all .3s
                width: 10px
                height: 10px
                border-radius: 2px
                background: $new-color---main
        p
            font-family: $font-family
            font-weight: 400
            font-size: 16px
            line-height: 1.3
            color: $new-color---policy
        a
            text-decoration: underline
            text-decoration-skip-ink: none
            color: $new-color---policy
            transition: all .3s
            &:hover
                color: $new-color---main
        input
            position: absolute
            left: 0
            opacity: 0
            &:checked
                &+b
                    &::before
                        opacity: 1
        &:has(input:checked)
            b
                &::before
                    opacity: 1

.consult
    padding: 180px 0 0
    .container
        max-width: 1320px
        box-sizing: border-box
        padding: 70px 60px 80px
        background: $new-bg---card
        border-radius: 5px
        display: grid
        grid-template-columns: 1fr 1fr
        gap: 20px
        align-items: start
    &__form
        padding: 20px 0 0
        .input
            &__text
                margin: 10px 0 0
            &__check
                margin: 15px 0 0
        .btn__brown
            margin: 25px 0 0
            width: 100%

.map
    padding: 180px 0 0
    &__wrapper
        margin: 50px 0 0
        position: relative
    &__iframe
        width: 100%
    &__info
        position: absolute
        bottom: 25px
        left: 25px
        width: 372px
        border-radius: 5px
        padding: 20px
        background: $new-bg---map
        p
            font-family: $second-family
            font-weight: 500
            font-size: 50px
            line-height: 1
            color: #000
            transition: all .3s
            &+p
                margin: 15px 0 0
                font-family: $font-family
                font-weight: 400
                font-size: 18px
                line-height: 1.3
                color: $new-color---text
                max-width: 196px
                transform: none !important
                opacity: 0
                transition: all .4s 
            &.active
                transition-delay: .4s
                opacity: 1
        &_city
            position: absolute
            bottom: 20px
            left: 20px
            right: 20px
            &:nth-child(2)
                position: relative
                inset: 0
            &.active
                opacity: 1
        &_num
            display: block
            position: relative
            overflow: hidden
            height: 50px
            span
                opacity: 0
                transform: translateY(100%)
                transition: all .5s 
                display: block
                position: absolute
                &.active
                    transition-delay: .4s
                    transform: translate(0)
                    opacity: 1
    &__icon
        position: absolute
        transition: all .9s
        transform: scale(2)
        opacity: 0
        cursor: pointer
        span
            display: flex
            justify-content: center
            align-items: center
            width: 46px
            height: 46px
            border-radius: 100%
            background: $new-color---point-fill
            transition: all .3s
            border: 1px solid $new-color---point-fill
        path
            transition: all .3s
        &:hover
            span
                border: 1px solid $new-stroke---point
        &.active
            span
                background: $new-color---main
                border: 1px solid $new-color---main
            path
                stroke: $new-bg---map
        &.is-visible
            opacity: 1
            transform: scale(1)
        
.about
    padding: 180px 0 0
    .container
        display: grid
        grid-template-columns: 1fr 1fr
        gap: 20px
    p
        max-width: 460px
    .btn__gray
        margin: 50px 0 0
    &__bg
        width: 100%
        height: 1px
        border-radius: 5px
        transition: all .3s
        position: relative
        overflow: hidden
        img
            height: 480px
            width: 100%
            transition: all .3s
            transform: scale(2)
            object-fit: cover
        &.is-visible
            height: 480px
            img
                transform: scale(1)

.stat
    padding: 180px 0
    &__wrapper
        margin: 50px 0 0
        display: grid
        grid-template-columns: 1fr 1fr 1fr
        gap: 10px
        align-items: end
    &__item
        border: 1px solid $new-stroke---main
        border-radius: 5px
        padding: 25px
        display: flex
        flex-direction: column
        min-height: 400px
        transition: all .3s
        p
            font-family: $second-family
            font-weight: 500
            font-size: 50px
            line-height: 1
            color: $old-black
            margin: 0 0 auto
            &+p
                margin: 20px 0 0
                font-family: $font-family
                font-weight: 400
                font-size: 20px
                line-height: 1.5
                color: $new-color---text
        &.is-visible
            &:nth-child(2)
                min-height: 320px
            &:nth-child(3)
                min-height: 240px

.footer
    padding: 50px 0 30px
    background: $new-bg---card
    &__container
        display: grid
        grid-template-columns: 280fr 280fr 280fr 280fr
        gap: 20px
    &__logo
        max-width: 120px
        display: block
        &_mob
            display: none
        img
            width: 100%
        svg
            width: 100%
        path
            transition: all .3s
        &:hover
            path
                fill: $button---hover
    &__list
        p
            font-family: $font-family
            font-weight: 400
            font-size: 18px
            line-height: 1.3
            color: $new-color---policy
            margin: 0 0 28px
        ul
            display: grid
            grid-template-columns: 1fr
            gap: 10px
            li
                font-family: $font-family
                font-weight: 400
                font-size: 20px
                line-height: 1.5
                color: #000
                transition: all .3s
            a
                color: #000
                transition: all .3s
                &:hover
                    color: $new-color---main
            .un
                text-decoration: underline
                text-decoration-skip-ink: none
            .modal__call
                margin: 18px 0 0
                transition: all .3s
                cursor: pointer
                &:hover
                    color: $new-color---main
    &__drop
        cursor: pointer
        color: #000
        margin: 0
        display: flex
        justify-content: start
        align-items: center
        gap: 7px
        position: relative
        p
            color: #000
            margin: 0
            font-size: 20px
            transition: all .3s
        &:hover
            p
                color: $new-color---main
        ol
            display: none
            position: absolute
            left: -20px
            top: calc( 100% + 10px )
            padding: 20px
            border-radius: 5px
            box-shadow: 0 9px 30px 0 rgba(0, 0, 0, 0.2)
            background: $new-bg---main
            z-index: 10
            grid-template-columns: 1fr 1fr
            gap: 15px
            width: 540px
        &.active
            ol
                display: grid
    &__descr
        margin: 87px 0 0
        padding: 25px 0 0
        border-top: 1px solid $new-footer---separator
        a
            transition: all .3s
            text-decoration: underline
            text-decoration-skip-ink: none
            &:hover
                color: $color---icon-header
        p,
        a
            display: block
            font-family: $font-family
            font-weight: 400
            font-size: 18px
            line-height: 1.3
            color: $new-color---policy
            max-width: 220px
        p
            a
                display: inline

.modal-b1
    width: 66px
    height: 66px
    position: fixed
    z-index: 5
    border: 6px solid #D9CFBF
    background: #a18161
    border-radius: 100%
    display: flex
    justify-content: center
    align-items: center
    bottom: 15px
    left: 15px
    cursor: pointer
    
.nav-fix
    position: fixed
    top: 50%
    right: 10px
    transform: translateY(-50%)
    z-index: 5
    padding: 0
    display: grid
    grid-template-columns: 1fr
    gap: 10px
    a
        width: 65px
        height: 65px
        border-radius: 5px
        background: $new-color---main
        transition: all .3s
        display: flex
        justify-content: center
        align-items: center
        &:hover
            background: $button---hover
    .btn__brown
        display: none

.nav-menu
    display: none


@media ( max-width: 1024px )
    .btn
        &__brown,
        &__gray
            padding: 1.25em 1.75em
            font-size: 20em
    body
        font-size: calc( 100vw / 1024 )
    .container
        padding: 0 20em
    .nav
        &-info
            padding: 17em 0
            &__info
                grid-template-columns: 16em 1fr
                gap: 8em
            svg
                width: 16em
            p
                font-size: 15em
        &__container
            padding: 20em 0
            .container
                gap: 20em
        &__logo
            max-width: 178em
            svg
                width: 100%
                height: 45em
        &__list
            gap: 30em
            a
                font-size: 18em
        &-dop
            &__btn
                grid-template-columns: 1fr 9em
                gap: 7em
                p
                    font-size: 18em
            &__wrapper
                padding: 30em 0 60em
                gap: 35em
                .container
                    grid-template-columns: 1fr 1fr 292em
                img
                    width: 100%
                a
                    font-size: 28em
                ul
                    gap: 25em
                    max-width: 300em
        &__phone
            grid-template-columns: 1fr 8em
            gap: 12em
            span
                width: 8em
                height: 8em
            p
                font-size: 18em
    .header
        padding: 120em 0 185em
        &__info
            h1
                font-size: 65em
                max-width: 10em
            p
                font-size: 20em
                margin: 1.2em 0 0
                max-width: 21em
        &__bg
            max-width: 1174em
            right: -236em
            bottom: -185em
            img
                pointer-events: none
            div
                right: 256em
                bottom: 20em
                padding: 18em 20em 15em
                p,
                p+p
                    font-size: 20em
    .title
        h2
            font-size: 60em
        p
            font-size: 20em
            margin: 1em 0 0
    .service
        padding: 180em 0 0
        &__wrapper
            margin: 50em 0 0
        &__item
            min-height: 280em
            grid-template-columns: 1fr 20em
            gap: 10em
            padding: 25em
            p
                font-size: 28em
    .consult
        padding: 180em 0 0
        .container
            padding: 70em 20em 80em
    .input
        &__text
            padding: 1.25em 1.25em
            font-size: 20em
        &__select
            position: relative
            input
                padding: 1.25em 1.25em
                font-size: 20em
            svg
                right: 25em
            ul
                li
                    font-size: 20em
                    padding: 1.25em 1.25em
        &__check
            grid-template-columns: 20em 1fr
            gap: 10em
            b
                width: 20em
                height: 20em
                &::before
                    width: 10em
                    height: 10em
            p
                font-size: 16em
    .map
        padding: 180em 0 0
        position: relative
        overflow: hidden
        &__wrapper
            margin: 50em 0 0
        &__icon
            span
                width: 46em
                height: 46em
            svg
                width: 12em
                height: 12em
        &__info
            width: 250em
            bottom: 25em
            left: 25em
            padding: 20em
            &_city
                bottom: 1.1em
                left: 1.1em
                right: 1.1em
            p
                font-size: 50em
                &+p
                    font-size: 18em
                    margin: 1.2em 0 0
            &_num
                height: 1em
    .about
        padding: 180em 0 0
        .container
            gap: 20em
        &__bg
            &.is-visible
                height: 480em
            img
                height: 480em
        .btn__gray
            margin: 2.5em 0 0
    .stat
        padding: 180em 0
        &__wrapper
            margin: 50em 0 0
            gap: 10em
        &__item
            padding: 25em
            min-height: 400em
            &.is-visible
                &:nth-child(2)
