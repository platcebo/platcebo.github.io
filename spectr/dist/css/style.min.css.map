                margin: 1em 0 0
        .swiper-pagination
            display: flex
            justify-content: center
            align-items: center
            inset: auto
            bottom: 0
            width: 100%
            left: 0
            gap: 10em
            span
                margin: 0 !important
                width: 8em
                height: 8em
                border-radius: 100%
                background: $new-footer---separator
                transition: all .3s
                opacity: 1
                &.swiper-pagination-bullet-active
                    background: $new-color---main
