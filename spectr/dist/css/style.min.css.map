    .nav-fix
        padding: 10em
        gap: 5em
        grid-template-columns: 1fr 50em 50em 50em
        a
            width: 50em
            height: 50em
            svg
                width: 20em
                height: 20em
        .btn__brown
            font-size: 15em
    .nav-menu
        display: flex
        flex-direction: column
        pointer-events: none
        // opacity: 0
        z-index: 100
        width: 100%
        height: 100vh
        overflow: auto
        padding: 15em 10em
        position: fixed
        top: 0
        left: 0
        background: $new-bg---main
        transform: translateY(-100%)
        transition: all .3s
        &__row
            display: flex
            justify-content: start
            align-items: center
            padding: 0 5em 0 0
            gap: 20em
        &.active
            transform: translate(0)
            pointer-events: auto
        .nav__hum
            position: relative
            span
                display: none
            &::before,
            &::after
                width: 25em
                position: absolute
                top: 50%
                left: 50%
                transform: translate(-50%, -50%) rotate(45deg)
            &::after
                transform: translate(-50%, -50%) rotate(-45deg)
        &__list
            margin: 70em 0 auto
            display: grid
            grid-template-columns: 1fr
            gap: 5px
            svg
                position: absolute
                top: 27em
                transform: translateY(-50%)
                right: 15em
                transition: all .3s
            li
                position: relative
                background: $new-bg---card
                border-radius: 5px
                &.nav-dop-js.active
                    svg
                        transform: rotate(180deg) translateY(50%)
                    ol
                        display: grid
            a
                display: block
                width: 100%
                padding: .68em
                font-family: $second-family
                font-weight: 500
                font-size: 22em
                line-height: 1.2
                color: #000
                text-align: center
            p
                display: block
                width: 100%
                padding: .68em
                font-family: $second-family
                font-weight: 500
                font-size: 22em
                line-height: 1.2
                color: #000
                text-align: center
                cursor: pointer
            ol
                padding: 5em 20em 24em
                grid-template-columns: 1fr
                gap: 17em
                display: none
                a
                    padding: 0
                    font-family: $font-family
                    font-weight: 400
                    font-size: 15em
                    line-height: 1.4
                    text-align: center
                    color: $new-color---text
        &__descr
            display: grid
            grid-template-columns: 1fr 1fr
            gap: 10em
            row-gap: 25em
            margin: 70em 0 0
            .btn__brown
                grid-column: 1/3
                width: 100%
                max-width: none
                font-size: 15em
                padding: 1.5em
            p
                font-family: $font-family
                font-weight: 400
                font-size: 12em
                line-height: 1.4
                color: $new-color---policy
                &+p
                    font-family: $font-family
                    font-weight: 400
                    font-size: 15em
                    line-height: 1.2
                    color: #000
                    margin: .8em 0 0
    section
        padding: 100em 0 0
