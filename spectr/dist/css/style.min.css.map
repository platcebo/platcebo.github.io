$color---arrow: #b5b5b5
$color---icon-header: #b0afa2
$color---text-header: #858279
$color---green: #58d97c
$stroke---devider-card: #d7d3c7
$bg---field-form: #fcfcf6
$button---hover: #79624b
$new-color---white: #fff
$new-color---text: #636057
$new-color---black: #1a1a1a
$new-color---main: #8d765f
$new-color---policy: #918d81
$new-color---point-fill: #eeeadd
$new-input---inactive: #b7b7b7
$new-bg---main: #f2f0ea
$new-bg---card: #e7e2d6
$new-bg---map: #fdfcf9
$new-bg---1-screen: #fdfcf9
$new-bg---header-up: #f7f6f3
$new-bg---header-down: #fefefd
$new-stroke---main: #dddbd5
$new-stroke---accent: #9d8975
$new-stroke---icon: #b9b5a9
$new-stroke---point: #918e85
$new-footer---category-title: #918d81
$new-footer---separator: #c3bfb3
$old-black: #2e2e2e
$old-card-line: #d1cec5
$old-icon-line: #b8b7ae
$old-text-light: #8c8a79
$old-text-dark: #504d44
$old-policy: #9c988d
$old-footer-descriptors: #8f8677
$old-bg: #efece3

$font-family: "Inter", sans-serif
$second-family: "PP Neue Montreal", sans-serif
$third-family: "Source Serif 4", sans-serif
$font3: "Evolventa", sans-serif
$font4: "Proxima Nova", sans-serif
$font5: "TT Norms", sans-serif
$font6: "Arial", sans-serif

@keyframes phone
    0%
        opacity: 1
    50% 
        opacity: 0
    100%
        opacity: 1

@keyframes navHumS
    0%
        opacity: 1
    50%
        opacity: 0
    100%
        opacity: 0
        

h1,
h2
    text-stroke: .75px #000
    -webkit-text-stroke: .75px #000
    
body
    background: $new-bg---main
    font-family: $font-family
    font-size: 1px
    &.fix
        position: relative
        overflow: hidden

section
    padding: 180px 0 0

.container
    max-width: 1200px
    padding: 0 20px
    margin: 0 auto
    box-sizing: content-box

.btn
    &__brown
        font-family: $font-family
        font-weight: 500
        font-size: 20px
        line-height: 1.2
        text-align: center
        color: $new-color---white
        position: relative
        transition: all .3s
        border-radius: 5px
        padding: 23px 35px
        background: $new-color---main
        border: none
        overflow: hidden
        min-width: 220px
        display: block
        width: max-content
        b
            position: relative
            display: block
            text-align: center
            overflow: hidden
        span
            transition: all .3s
            display: block
            transition-delay: 0s !important
            &:nth-child(2)
                width: 100%
                position: absolute
                top: 50%
                left: 50%
                transform: translate(-50%,110%)
        &:hover
            background: $button---hover
            span
                &:nth-child(1)
                    transform: translateY(-110%)
                &:nth-child(2)
                    transform: translate(-50%,-50%)
    &__gray
        font-family: $font-family
        font-weight: 500
        font-size: 20px
        line-height: 1
        text-align: center
        color: #000
        position: relative
        transition: all .3s
        border-radius: 5px
        padding: 24px 34px
        background: transparent
        border: 1px solid $new-stroke---main
        overflow: hidden
        min-width: 220px
        display: block
        width: max-content
        b
            position: relative
            display: block
            text-align: center
            overflow: hidden
        span
            transition: all .3s
            display: block
            transition-delay: 0s !important
            &:nth-child(2)
                width: 100%
                position: absolute
                top: 50%
                left: 50%
                transform: translate(-50%,70px)
        &:hover
            background: $button---hover
            border: 1px solid $button---hover
            color: $new-color---white
            span
                &:nth-child(1)
                    transform: translateY(-70px)
                &:nth-child(2)
                    transform: translate(-50%,-50%)

.title
    h2
        font-family: $font3
        font-weight: 400
        font-size: 60px
        line-height: 1.2
        letter-spacing: 0.02em
        color: #000
    p
        max-width: 410px
        margin: 20px 0 0
        font-family: $font-family
        font-weight: 400
        font-size: 20px
        line-height: 1.5
        color: $new-color---text

.title__anim
    opacity: 1
    transition: all 0.8s ease
    b
        position: relative
        overflow: hidden
        display: inline
        &:nth-child(1)  span
            transition-delay: 0.4s 
        &:nth-child(2)  span
            transition-delay: 0.6s 
        &:nth-child(3)  span
            transition-delay: 0.8s 
        &:nth-child(4)  span
            transition-delay: 1s 
        &:nth-child(5)  span
            transition-delay: 1.2s 
        &:nth-child(6)  span
            transition-delay: 1.4s 
        &:nth-child(7)  span
            transition-delay: 1.6s 
    h2 ,
    h1
        position: relative
        overflow: hidden
        display: block
        b
            position: relative
            overflow: hidden
        span
            display: inline-block
            opacity: 0
            transform: translateY(100%)
            transition: all 0.6s ease 0s
    h1
        &+p
            b
                &:nth-child(1)  span
                    transition-delay: 1s 
                &:nth-child(2)  span
                    transition-delay: 1.2s 
                &:nth-child(3)  span
                    transition-delay: 1.4s 
                &:nth-child(4)  span
                    transition-delay: 1.6s 
                &:nth-child(5)  span
                    transition-delay: 1.7s 
                &:nth-child(6)  span
                    transition-delay: 1.8s 
                &:nth-child(7)  span
                    transition-delay: 2s 
    p 
        span 
            display: inline-block
            opacity: 0
            transform: translateY(20px)
            transition: all 0.6s ease
    &.is-visible 
        h2 ,
        h1
            span
                opacity: 1
                transform: translateY(0)
        p span 
            opacity: 1
            transform: translateY(0)

h1.title__anim
    position: relative
    overflow: hidden
    display: block
    b
        position: relative
        overflow: hidden
        display: block
    span
        display: inline-block
        opacity: 0
        transform: translateY(100%)
        transition: all 0.6s ease 0.2s
    &.is-visible 
        span
            opacity: 1
            transform: translateY(0)
    
.nav
    position: sticky
    top: -100%
    z-index: 6
    transition: all .4s
    margin: 0 0 -1px
    &__overflow
        position: fixed
        z-index: -1
        top: 0
        left: 0
        width: 100vw
        height: 100vh
        background: #000
        cursor: pointer
        pointer-events: none
        opacity: 0
        transition: all .3s
    &.drop
        .nav__overflow
            opacity: .5
            pointer-events: auto
    &.active
        top: 0
    &__hum
        display: none
    &-info
        background: $new-bg---header-up
        padding: 17px 0
        .container
            display: flex
            justify-content: start
            align-items: center
            gap: 35px
        &__info
            display: grid
            grid-template-columns: 16px 1fr
            gap: 8px
            align-items: center
        p
            font-family: $font-family
            font-weight: 400
            font-size: 15px
            line-height: 1.3
            color: $color---text-header
            transition: all .3s
        path
            transition: all .3s
            fill: $color---text-header
        .modal__call
            margin: 0 0 0 auto
            cursor: pointer
        .modal__call,
        a
            &:hover
                path,
                p
                    fill: $new-color---main
                    color: $new-color---main
    &__container
        padding: 20px 0
        background: $new-bg---header-down
        position: relative
        .container
            gap: 20px
            display: flex
            justify-content: start
            align-items: center
    &__logo
        max-width: 178px
        display: block
        img
            width: 100%
        svg
            width: 100%
        path
            transition: all .3s
        &:hover
            path
                fill: $button---hover
    &__list
        margin: 0 auto
        display: flex
        justify-content: start
        align-items: center
        gap: 35px
    &__link
        a
            font-family: $font-family
            font-weight: 400
            font-size: 18px
            line-height: 1.3
            color: #000
            transition: all .3s
            &:hover
                color: $new-color---main
    &__phone
        display: grid
        grid-template-columns: 1fr 8px
        gap: 12px
        align-items: center
        span
            display: block
            width: 8px
            height: 8px
            border-radius: 100%
            background: #58D97C
            animation: phone 2s infinite
        p
            font-family: $font-family
            font-weight: 400
            font-size: 18px
            line-height: 1.3
            color: #000
            transition: all .3s
            &:hover
                color: $new-color---main
    &-dop
        &__btn
            display: grid
            grid-template-columns: 1fr 9px
            gap: 7px
            align-items: center
            cursor: pointer
            p
                font-family: $font-family
                font-weight: 400
                font-size: 18px
                line-height: 1.3
                color: #000
                transition: all .3s
                &:hover
                    color: $new-color---main
            svg
                transition: all .3s
        &__wrapper
            position: absolute
            left: 0
            width: 100%
            top: calc( 100% - 1px )
            background: $new-bg---header-down
            // display: none
            padding: 30px 0 60px
            z-index: 5
            transform: translateY(-150%)
            transition: all .3s
            .container
                display: grid
                grid-template-columns: 337px 337px 1fr
                gap: 20px
                align-items: flex-start !important
            ul
                display: grid
                grid-template-columns: 1fr
                gap: 25px
            a
                font-family: $second-family
                font-weight: 500
                font-size: 28px
                line-height: 1.2
                transition: all .3s
                color: #000
                &:hover
                    color: $new-color---main
            img
                width: 100%
                max-width: 292px
                margin: 0 0 0 auto
                display: block
                border-radius: 5px
        &.active
            .nav-dop
                &__wrapper
                    transform: translateY(0%)
                &__btn
                    p
                        color: $new-color---main
                    svg
                        transform: rotate(180deg)

.header
    padding: 120px 0 184px
    position: relative
    overflow: hidden
    background: url('../img/header.png') top no-repeat
    background-size: cover
    z-index: 2
    .container
        position: relative
    &__info
        h1
            font-family: $font3
            font-weight: 400
            font-size: 65px
            line-height: 1.2
            letter-spacing: 0.02em
            color: #000
            max-width: 700px
        p
            margin: 25px 0 0
            font-family: $font-family
            font-weight: 400
            font-size: 20px
            line-height: 1.5
            color: $new-color---text
            max-width: 410px
        .btn__brown
            margin: 35px 0 0
    &__bg
        position: absolute
        right: -210px
        width: 1174px
        bottom: -184px
        z-index: -1
        img
            width: 100%
        div
            position: absolute
            right: 235px
            bottom: 116px
            border-radius: 5px
            padding: 18px 20px 15px
            background: $new-color---white
            p
                font-family: $font-family
                font-weight: 500
                font-size: 20px
                line-height: 1
                color: #000
                &+p
                    margin: 5px 0 0
                    font-family: $font-family
                    font-weight: 400
                    font-size: 20px
                    line-height: 1.5
                    color: $new-stroke---point

.service
    padding: 180px 0 0
    &__wrapper
        display: grid
        grid-template-columns: 1fr 1fr 1fr
        gap: 10px
        margin: 50px 0 0
    &__item
        min-height: 280px
        border-radius: 5px
        transition: all .3s
        display: grid
        grid-template-columns: 1fr 20px
        gap: 10px
        background: $new-bg---card
        padding: 25px
        align-items: start
        p
            font-family: $second-family
            font-weight: 500
            font-size: 28px
            line-height: 1.2
            color: #000
            transition: all .3s
        span
            margin: 6px 0 0
            display: block
            position: relative
            overflow: hidden
        svg
            transition: all .3s
            &:nth-child(2)
                position: absolute
                top: 0
                right: 0
                transform: translate(-100%, 100%)
        path
            transition: all .3s
        &:hover
            background: $new-color---main
            p
                color: $new-color---white
            svg
                transform: translate(100%, -100%)
                &:nth-child(2)
                    transform: translate(0%, 0%)

.input
    &__text
        border-radius: 5px
        padding: 23px 25px
        width: 100%
        box-sizing: border-box
        background: $new-color---white
        font-family: $font-family
        font-weight: 500
        font-size: 20px
        line-height: 1
        color: #000
        border: none
        &::placeholder
            color: $new-input---inactive
    &__select
        position: relative
        input
            border-radius: 5px
            padding: 23px 25px
            width: 100%
            box-sizing: border-box
            background: $new-color---white
            font-family: $font-family
            font-weight: 500
            font-size: 20px
            line-height: 1
            color: #000
            border: none
            cursor: pointer
            &::placeholder
                color: $new-input---inactive
        svg
            right: 25px
            top: 50%
            transform: translateY(-50%)
            position: absolute
        ul
            position: absolute
            z-index: 2
            left: 0
            top: 100%
            width: 100%
            display: none
            li
                font-family: $font-family
                font-weight: 500
                font-size: 20px
                line-height: 1
                color: #000
                background: $new-color---white
                padding: 23px 25px
                transition: all .3s
                cursor: pointer
                &:hover
                    background: $new-bg---main
                &.active
                    background: $new-bg---main
        &.active
            ul
                display: block
            input
                border-radius: 5px 5px 0 0
    &__check
        display: grid
        grid-template-columns: 20px 1fr
        gap: 10px
        align-items: start
        position: relative
        span.wpcf7-form-control-wrap
            position: absolute !important
        b
            border: 1px solid #9a968a
            border-radius: 4px
            width: 20px
            height: 20px
            display: flex
            justify-content: center
            align-items: center
            cursor: pointer
            &::before
                content: ''
                display: block
                opacity: 0
                transition: all .3s
                width: 10px
                height: 10px
                border-radius: 2px
                background: #9a968a
        p
            font-family: $font-family
            font-weight: 400
            font-size: 16px
            line-height: 1.3
            color: $new-color---policy
        a
            text-decoration: underline
            text-decoration-skip-ink: none
            color: $new-color---policy
            transition: all .3s
            &:hover
                color: $new-color---main
        input
            position: absolute
            left: 0
            opacity: 0
            &:checked
                &+b
                    &::before
                        opacity: 1
        &:has(input:checked)
            b
                &::before
                    opacity: 1

.consult
    padding: 180px 0 0
    .container
        max-width: 1320px
        box-sizing: border-box
        padding: 70px 60px 80px
        background: $new-bg---card
        border-radius: 5px
        display: grid
        grid-template-columns: 1fr 1fr
        gap: 20px
        align-items: start
    &__form
        padding: 20px 0 0
        .input
            &__text
                margin: 10px 0 0
            &__check
                margin: 15px 0 0
        .btn__brown
            margin: 25px 0 0
            width: 100%

.map
    padding: 180px 0 0
    &__wrapper
        margin: 50px 0 0
        position: relative
    &__iframe
        width: 100%
    &__info
        position: absolute
        bottom: 25px
        left: 25px
        width: 372px
        border-radius: 5px
        padding: 20px
        background: $new-bg---map
        p
            font-family: $second-family
            font-weight: 500
            font-size: 50px
            line-height: 1
            color: #000
            transition: all .3s
            &+p
                margin: 15px 0 0
                font-family: $font-family
                font-weight: 400
                font-size: 18px
                line-height: 1.3
                color: $new-color---text
                max-width: 196px
                transform: none !important
                opacity: 0
                transition: all .4s 
            &.active
                transition-delay: .4s
                opacity: 1
        &_city
            position: absolute
            bottom: 20px
            left: 20px
            right: 20px
            &:nth-child(2)
                position: relative
                inset: 0
            &.active
                opacity: 1
        &_num
            display: block
            position: relative
            overflow: hidden
            height: 50px
            span
                opacity: 0
                transform: translateY(100%)
                transition: all .5s 
                display: block
                position: absolute
                &.active
                    transition-delay: .4s
                    transform: translate(0)
                    opacity: 1
    &__icon
        position: absolute
        transition: all .9s
        transform: scale(2)
        opacity: 0
        cursor: pointer
        span
            display: flex
            justify-content: center
            align-items: center
            width: 46px
            height: 46px
            border-radius: 100%
            background: $new-color---point-fill
            transition: all .3s
            border: 1px solid $new-color---point-fill
        path
            transition: all .3s
        &:hover
            span
                border: 1px solid $new-stroke---point
        &.active
            span
                background: $new-color---main
                border: 1px solid $new-color---main
            path
                stroke: $new-bg---map
        &.is-visible
            opacity: 1
            transform: scale(1)
        
.about
    padding: 180px 0 0
    &__mob
        display: none
    .container
        display: grid
        grid-template-columns: 1fr 1fr
        gap: 20px
    p
        max-width: 460px
        margin: 30px 0 0
    .btn__gray
        margin: 50px 0 0
    &__info
        opacity: 1
        transform: none
    &__bg
        width: 100%
        border-radius: 5px
        transition: all .6s
        position: relative
        overflow: hidden
        transform-origin: 0 0
        height: 0
        transition-delay: 1s
        img
            width: 100%
            transition: all .6s
            transform-origin: 50% 0 
            transform: scale(1.5)
            object-fit: cover
            transition-delay: 1s
        &.is-visible
            height: 100%
            img
                transform: scale(1)
    &__text
        margin: 30em 0 0
        display: grid
        grid-template-columns: 1fr
        gap: 20em
        p
            margin: 0

.stat
    padding: 180px 0 0
    &__wrapper
        margin: 50px 0 0
        display: grid
        grid-template-columns: 1fr 1fr 1fr
        gap: 10px
        align-items: end
    &__item
        border: 1px solid $new-stroke---main
        border-radius: 5px
        padding: 25px
        display: flex
        flex-direction: column
        min-height: 400px
        transition: all 1s
        p
            font-family: $second-family
            font-weight: 500
            font-size: 50px
            line-height: 1
            color: $old-black
            margin: 0 0 auto
            &+p
                margin: 20px 0 0
                font-family: $font-family
                font-weight: 400
                font-size: 20px
                line-height: 1.5
                color: $new-color---text
        &.is-visible
            &:nth-child(2)
                min-height: 320px
            &:nth-child(3)
                min-height: 240px

.footer
    padding: 50px 0 30px
    background: $new-bg---card
    margin: 180px 0 0
    &__container
        display: grid
        grid-template-columns: 280fr 280fr 280fr 280fr
        gap: 20px
    &__logo
        max-width: 120px
        display: block
        &_mob
            display: none
        img
            width: 100%
        svg
            width: 100%
            height: 93em
        path
            transition: all .3s
        &:hover
            path
                fill: $button---hover
    &__list
        p
            font-family: $font-family
            font-weight: 400
            font-size: 18px
            line-height: 1.3
            color: $new-color---policy
            margin: 0 0 28px
        ul
            display: grid
            grid-template-columns: 1fr
            gap: 10px
            li
                font-family: $font-family
                font-weight: 400
                font-size: 20px
                line-height: 1.5
                color: #000
                transition: all .3s
            a
                color: #000
                transition: all .3s
                &:hover
                    color: $new-color---main
            .un
                text-decoration: underline
                text-decoration-skip-ink: none
            .modal__call
                margin: 18px 0 0
                transition: all .3s
                cursor: pointer
                &:hover
                    color: $new-color---main
        &_nav
            ul
                gap: 12em
    &__drop
        cursor: pointer
        color: #000
        margin: 0
        display: flex
        justify-content: start
        align-items: center
        gap: 7px
        position: relative
        p
            color: #000
            margin: 0
            font-size: 20px
            transition: all .3s
        &:hover
            p
                color: $new-color---main
        ol
            font-size: 1px
            display: none
            position: absolute
            left: -20px
            top: calc( 100% + 10px )
            padding: 20px
            border-radius: 5px
            box-shadow: 0 9px 30px 0 rgba(0, 0, 0, 0.2)
            background: $new-bg---main
            z-index: 10
            gap: 15px
            width: 540px
            flex-direction: column
            flex-wrap: wrap
            max-height: 260em
            li
                max-width: 242px
                line-height: 1.2
            a
                line-height: 1.2
        &.active
            ol
                display: flex
    &__descr
        margin: 87px 0 0
        padding: 25px 0 0
        border-top: 1px solid $new-footer---separator
        a
            transition: all .3s
            text-decoration: underline
            text-decoration-skip-ink: none
            &:hover
                color: $color---icon-header
        p,
        a
            display: block
            font-family: $font-family
            font-weight: 400
            font-size: 18px
            line-height: 1.3
            color: $new-color---policy
            max-width: 220px
        p
            a
                display: inline

.modal-b1
    width: 66px
    height: 66px
    position: fixed
    z-index: 5
    border: 6px solid #D9CFBF
    background: #a18161
    border-radius: 100%
    display: flex
    justify-content: center
    align-items: center
    bottom: 15px
    left: 15px
    cursor: pointer
    
.nav-fix
    position: fixed
    top: 50%
    right: 10px
    transform: translateY(-50%)
    z-index: 5
    padding: 0
    display: grid
    grid-template-columns: 1fr
    gap: 10px
    a
        width: 65px
        height: 65px
        border-radius: 5px
        background: $new-color---main
        transition: all .3s
        display: flex
        justify-content: center
        align-items: center
        &:hover
            background: $button---hover
    .btn__brown
        display: none

.nav-menu
    display: none

.header-section
    padding: 133px 0 60px
    position: relative
    background: url('../img/header.png') top no-repeat
    background-size: cover
    h1
        font-family: $font3
        font-weight: 400
